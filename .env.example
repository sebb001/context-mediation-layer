# Copy to .env for local development. Never commit real values.

# Governance storage
CML_CONFIG=./cml.config.json
CML_DB_PATH=./var/cml.sqlite
CML_SCOPE=default

# Local MCP server
CML_MCP_TOKEN=replace-with-local-dev-token
CML_MCP_HTTP_HOST=127.0.0.1
CML_MCP_HTTP_PORT=8787

# Public MCP bridge
CML_PUBLIC_MCP_TOKEN=replace-with-public-bridge-token
CML_PUBLIC_MCP_UPSTREAM_URL=http://127.0.0.1:8787/mcp
CML_PUBLIC_MCP_UPSTREAM_TOKEN=replace-with-local-upstream-token
CML_PUBLIC_MCP_HOST=127.0.0.1
CML_PUBLIC_MCP_PORT=8788
CML_PUBLIC_MCP_BASE_URL=http://127.0.0.1:8788

# Optional OAuth/OIDC for public MCP bridge
CML_OAUTH_ISSUER=
CML_OAUTH_RESOURCE=http://127.0.0.1:8788/mcp
CML_OAUTH_AUDIENCE=http://127.0.0.1:8788/mcp
CML_OAUTH_SCOPES=cml:read
CML_OAUTH_JWKS_URL=
CML_OAUTH_SUBJECT_ACTOR_MAP=
CML_OAUTH_GROUP_ACTOR_MAP=
CML_OAUTH_DEFAULT_ACTOR=

# Optional built-in pilot OAuth issuer. Generate real local values with:
# npm run oauth:bootstrap -- --base-url https://your-public-mcp.example
CML_OAUTH_PILOT_ISSUER=0
CML_OAUTH_PRIVATE_KEY_PATH=
CML_OAUTH_KEY_ID=
CML_OAUTH_CLIENT_STORE_PATH=./var/oauth/clients.json
CML_OAUTH_AUTH_SECRET=
CML_OAUTH_PILOT_SUBJECT=pilot-user
CML_OAUTH_PILOT_GROUPS=

# Actor defaults
CML_ACTOR=local-operator
CML_ACTOR_ID=
CML_PROVIDER=human

# Optional vault integration
CML_VAULT_ROOT=./vault
CML_OBSIDIAN_BIN=
CML_OBSIDIAN_VAULT=
